{
  "name": "@bgstm/playwright-core",
  "version": "0.0.0",
  "private": true,
  "description": "Shared fixtures, base POM, and BGSTM reporter for Playwright",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reporter": {
      "types": "./dist/reporter/index.d.ts",
      "default": "./dist/reporter/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.48.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
